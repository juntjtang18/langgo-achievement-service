{
  "name": "langgo-achievement-server",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone achievement system service for LangGo.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "generate:restore-sql": "node scripts/generate-restore-sql.mjs",
    "start": "node dist/src/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "event-bus-client": "github:juntjtang18/event-bus-client#main",
    "express": "^4.21.2",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "pg": "^8.16.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.29",
    "@types/pg": "^8.15.2",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
